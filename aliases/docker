
alias dcup="docker-compose up -d"
alias dcdown="docker-compose down"
alias dps="sudo docker ps -a"
alias dpsa="dps"

dssh() {
  docker exec -i -t "$1" bash
}

dbash() {
  _load_vars
  dexec $DRUPAL_WEB_CONTAINER_NAME bash
}

dexec() {
  CONTAINER_NAME="$1"
  shift 1
  echo "docker exec -i -t $CONTAINER_NAME $@"
  docker exec -i -t $CONTAINER_NAME $@
}

ddrush() {
  _load_vars
  dexec "$DRUPAL_WEB_CONTAINER_NAME" /var/www/html/vendor/bin/drush $@
}

alias dd="ddrush"

dcomposer() {
  _load_vars
  dexec "$DRUPAL_WEB_CONTAINER_NAME" composer $@
}

